# LLM API Configuration
# 智谱 AI Coding API
OPENAI_API_KEY=your_api_key_here

# Custom baseURL for compatible APIs
# Zhipu AI Coding API: https://open.bigmodel.cn/api/coding/paas/v4
# Zhipu AI General API: https://open.bigmodel.cn/api/paas/v4
# OpenAI: https://api.openai.com/v1
OPENAI_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4

# Default model to use
# For Zhipu AI Coding: glm-5
# For Zhipu AI General: glm-4-plus, glm-4-0520, glm-4, glm-4-air, glm-4-flash
# For OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
OPENAI_DEFAULT_MODEL=glm-5

# ===== LangChain Configuration =====
# LangChain 使用相同的 OPENAI_API_KEY、OPENAI_BASE_URL 和 OPENAI_DEFAULT_MODEL
# 可选的 LangChain 特定配置
LANGCHAIN_TEMPERATURE=0.7
LANGCHAIN_VERBOSE=true

# ===== Agent Tools Configuration (Optional) =====
# SERPAPI_API_KEY=your_serpapi_key_here

# ===== LangSmith Tracing (Optional) =====
# LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=your_langsmith_key
# LANGCHAIN_PROJECT=ai-agent-langchain-demo

# Server port (default: 3000)
PORT=3000
