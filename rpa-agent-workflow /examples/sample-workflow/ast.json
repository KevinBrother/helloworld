{
  "schemaVersion": "1.0.0",
  "workflow": {
    "id": "sample_workflow",
    "name": "Sample Workflow"
  },
  "variables": [
    {
      "name": "last_item",
      "type": {
        "name": "string"
      },
      "mutable": true
    },
    {
      "name": "finally_ran",
      "type": {
        "name": "boolean"
      },
      "mutable": true
    }
  ],
  "body": {
    "id": "root",
    "kind": "sequence",
    "statements": [
      {
        "id": "start_log",
        "kind": "callBlock",
        "block": "core.log",
        "inputs": {
          "message": {
            "kind": "literal",
            "value": "starting sample workflow"
          }
        }
      },
      {
        "id": "if_log",
        "kind": "if",
        "condition": {
          "kind": "literal",
          "value": true
        },
        "then": [
          {
            "id": "then_log",
            "kind": "callBlock",
            "block": "core.log",
            "inputs": {
              "message": {
                "kind": "literal",
                "value": "if branch executed"
              }
            }
          }
        ],
        "else": []
      },
      {
        "id": "foreach_items",
        "kind": "loop",
        "loopKind": "foreach",
        "iterable": {
          "kind": "array",
          "items": [
            {
              "kind": "literal",
              "value": "first"
            },
            {
              "kind": "literal",
              "value": "second"
            }
          ]
        },
        "itemVar": "item",
        "statements": [
          {
            "id": "assign_last_item",
            "kind": "assign",
            "target": "last_item",
            "value": {
              "kind": "ref",
              "ref": "item"
            }
          }
        ]
      },
      {
        "id": "parallel_system_info",
        "kind": "parallel",
        "join": {
          "strategy": "all",
          "onError": "failFast"
        },
        "branches": [
          {
            "id": "os_branch",
            "body": [
              {
                "id": "get_os_info",
                "kind": "callBlock",
                "block": "system.get_os_info"
              }
            ]
          },
          {
            "id": "log_branch",
            "body": [
              {
                "id": "parallel_log",
                "kind": "callBlock",
                "block": "core.log",
                "inputs": {
                  "message": {
                    "kind": "literal",
                    "value": "parallel branch executed"
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "id": "try_finally",
        "kind": "try",
        "statements": [],
        "catches": [
          {
            "pattern": "*",
            "body": []
          }
        ],
        "finally": [
          {
            "id": "assign_finally",
            "kind": "assign",
            "target": "finally_ran",
            "value": {
              "kind": "literal",
              "value": true
            }
          }
        ]
      },
      {
        "id": "return_outputs",
        "kind": "return",
        "returns": {
          "last_item": {
            "kind": "ref",
            "ref": "var.last_item"
          },
          "finally_ran": {
            "kind": "ref",
            "ref": "var.finally_ran"
          }
        }
      }
    ]
  }
}
