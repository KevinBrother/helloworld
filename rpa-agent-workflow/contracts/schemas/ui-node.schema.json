{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/rpa-agent-workflow/ui-node.schema.json",
  "title": "UI Node Document",
  "type": "object",
  "required": ["schemaVersion", "workflowId", "root"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "workflowId": { "type": "string" },
    "root": { "$ref": "#/$defs/node" },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false,
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "kind", "path", "capabilities"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "label": { "type": "string" },
        "path": { "type": "string" },
        "children": { "type": "array", "items": { "$ref": "#/$defs/node" } },
        "branches": { "type": "array", "items": { "$ref": "#/$defs/branch" } },
        "layout": { "$ref": "#/$defs/layout" },
        "collapsed": { "type": "boolean" },
        "editable": { "type": "boolean" },
        "capabilities": { "$ref": "#/$defs/capabilities" },
        "inspector": { "type": "array", "items": { "$ref": "#/$defs/inspectorField" } },
        "validationSummary": { "$ref": "#/$defs/validationSummary" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "branch": {
      "type": "object",
      "required": ["id", "kind", "children"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "kind": { "type": "string" },
        "children": { "type": "array", "items": { "$ref": "#/$defs/node" } }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "object",
      "properties": {
        "toggleCollapsed": { "$ref": "#/$defs/capability" },
        "updateField": { "$ref": "#/$defs/capability" },
        "insertNode": { "$ref": "#/$defs/capability" },
        "deleteNode": { "$ref": "#/$defs/capability" },
        "moveStatement": { "$ref": "#/$defs/capability" },
        "duplicateNode": { "$ref": "#/$defs/capability" },
        "replaceSubtree": { "$ref": "#/$defs/capability" }
      },
      "additionalProperties": false
    },
    "capability": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "label": { "type": "string" },
        "reason": { "type": "string" },
        "targetPath": { "type": "string" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "layout": {
      "type": "object",
      "properties": {
        "direction": { "type": "string" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "lane": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "inspectorField": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string" },
        "label": { "type": "string" },
        "control": {
          "type": "string",
          "enum": ["text", "textarea", "number", "select", "switch", "expression", "json", "port"]
        },
        "value": {},
        "readonly": { "type": "boolean" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "validationSummary": {
      "type": "object",
      "properties": {
        "errors": { "type": "integer" },
        "warnings": { "type": "integer" }
      },
      "additionalProperties": false
    }
  }
}
