{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/rpa-agent-workflow/edit-operation.schema.json",
  "title": "Edit Operation",
  "type": "object",
  "required": ["schemaVersion", "operationId", "type"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "operationId": { "type": "string" },
    "type": {
      "type": "string",
      "enum": [
        "toggleCollapsed",
        "updateField",
        "insertNode",
        "insertBranch",
        "deleteNode",
        "moveStatement",
        "duplicateNode",
        "replaceSubtree"
      ]
    },
    "targetNodeId": { "type": "string" },
    "path": { "type": "string" },
    "payload": { "$ref": "#/$defs/payload" },
    "actor": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "kind": { "type": "string" }
      },
      "additionalProperties": true
    },
    "metadata": { "type": "object" }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "toggleCollapsed" } }, "required": ["type"] },
      "then": {
        "required": ["targetNodeId", "payload"],
        "properties": {
          "payload": {
            "type": "object",
            "required": ["collapsed"],
            "properties": {
              "collapsed": { "type": "boolean" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "updateField" } }, "required": ["type"] },
      "then": {
        "required": ["targetNodeId", "path", "payload"],
        "properties": {
          "path": {
            "type": "string",
            "anyOf": [
              { "pattern": "^metadata\\.[A-Za-z0-9_.-]+$" },
              { "pattern": "^\\$\\.body(\\.[A-Za-z]+(\\[[0-9]+\\])?)*(\\.(inputs|outputs|returns)\\.[A-Za-z0-9_-]+|\\.(value|condition|iterable))$" }
            ]
          },
          "payload": {
            "type": "object",
            "required": ["value"],
            "properties": {
              "value": {}
            },
            "additionalProperties": true
          }
        }
      }
    }
  ],
  "$defs": {
    "payload": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
