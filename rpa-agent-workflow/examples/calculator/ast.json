{
  "schemaVersion": "1.0.0",
  "workflow": {
    "id": "calculator",
    "name": "Calculator"
  },
  "inputs": [
    {
      "name": "left",
      "type": {
        "name": "string"
      }
    },
    {
      "name": "operator",
      "type": {
        "name": "string"
      }
    },
    {
      "name": "right",
      "type": {
        "name": "number"
      }
    }
  ],
  "outputs": [
    {
      "name": "result",
      "type": {
        "name": "number"
      }
    }
  ],
  "body": {
    "id": "root",
    "kind": "sequence",
    "statements": [
      {
        "id": "branch_by_threshold",
        "kind": "if",
        "outputs": {
          "result": {
            "kind": "branch",
            "fields": {
              "else": {
                "kind": "ref",
                "ref": "node.calculate_small_value.result"
              },
              "then": {
                "kind": "ref",
                "ref": "node.calculate_large_value.result"
              }
            }
          }
        },
        "condition": {
          "kind": "binary",
          "op": "\u003e",
          "left": {
            "kind": "ref",
            "ref": "input.left"
          },
          "right": {
            "kind": "literal",
            "value": 10
          }
        },
        "then": [
          {
            "id": "calculate_large_value",
            "kind": "callBlock",
            "block": "math.calculate",
            "inputs": {
              "left": {
                "kind": "ref",
                "ref": "input.left"
              },
              "operator": {
                "kind": "ref",
                "ref": "input.operator"
              },
              "right": {
                "kind": "ref",
                "ref": "input.right"
              }
            }
          }
        ],
        "else": [
          {
            "id": "calculate_small_value",
            "kind": "callBlock",
            "block": "math.calculate",
            "inputs": {
              "left": {
                "kind": "ref",
                "ref": "input.left"
              },
              "operator": {
                "kind": "ref",
                "ref": "input.operator"
              },
              "right": {
                "kind": "ref",
                "ref": "input.right"
              }
            }
          }
        ],
        "metadata": {
          "ui": {
            "collapsed": false
          }
        }
      },
      {
        "id": "return_result",
        "kind": "return",
        "returns": {
          "result": {
            "kind": "ref",
            "ref": "node.branch_by_threshold.result"
          }
        }
      }
    ]
  }
}
